# Normalize line endings: LF in the repo, auto on checkout.
* text=auto eol=lf

# Scripts must stay LF even on Windows checkouts.
*.sh   text eol=lf
gradlew text eol=lf

# Windows batch script must be CRLF.
*.bat  text eol=crlf

# Binary assets — never modify.
*.jar  binary
*.aar  binary
*.bin  binary
*.png  binary
